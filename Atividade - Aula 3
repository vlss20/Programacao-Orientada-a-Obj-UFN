5)
Classe Produto:

package Package;

public class Produto {
    String nome;
    double preco;
    int qtEmEstoque;
}

---------------------------
ExecutaProduto:

package Package;

import java.util.Scanner;

public class ExecutaProduto {

    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);
 
        Produto meuProduto = new Produto();
        
        System.out.println("CADASTRO DE PRODUTO");
        
        System.out.print("Digite o nome do produto: ");
        meuProduto.nome = teclado.nextLine();

        System.out.print("Digite o preco unitario: R$ ");
        meuProduto.preco = teclado.nextDouble();
        
        System.out.print("Digite a quantidade em estoque: ");
        meuProduto.qtEmEstoque = teclado.nextInt();
        
        double valorTotEstoque = meuProduto.preco * meuProduto.qtEmEstoque;
 
        System.out.println("\nRESUMO");
        System.out.println("Produto: " + meuProduto.nome);
        System.out.println("Preço unitario: R$ " + meuProduto.preco);
        System.out.println("Quantidade: " + meuProduto.qtEmEstoque + " unidades");
        System.out.println("Valor Total em Estoque: R$ " + valorTotEstoque);
        
        teclado.close();
    }
}

