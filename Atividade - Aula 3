6)
Classe Aluno:

package Package;

public class Aluno {
    String nome;
    String matricula;
    double n1;
    double n2;
    double n3;
}

---------------------------
ExecutaAluno:

package Package;

import java.util.Scanner;

public class ExecutaAluno {

    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);
        
        Aluno meuAluno = new Aluno();
        
        System.out.println("SISTEMA DE NOTAS");
        
        System.out.print("Digite o nome do aluno: ");
        meuAluno.nome = teclado.nextLine();
        
        System.out.print("Digite a matrícula: ");
        meuAluno.matricula = teclado.nextLine();
        
        System.out.print("Digite a nota 1: ");
        meuAluno.n1 = teclado.nextDouble();
        
        System.out.print("Digite a nota 2: ");
        meuAluno.n2 = teclado.nextDouble();
        
        System.out.print("Digite a nota 3: ");
        meuAluno.n3 = teclado.nextDouble();
        
        double media = (meuAluno.n1 + meuAluno.n2 + meuAluno.n3) / 3;
        
        System.out.println("\nBOLETIM DO ALUNO");
        System.out.println("Nome: " + meuAluno.nome);
        System.out.println("Matricula: " + meuAluno.matricula);
        System.out.println("Media Final: " + media);
        
        if (media >= 6) {
            System.out.println("APROVADO!");
        } else {
            System.out.println("REPROVADO!");
        }
        
        teclado.close();
    }
}

