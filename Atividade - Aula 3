package Package;

import java.util.Scanner;

public class ExecutaComputador {

    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);
        
        Computador comp1 = new Computador(); 
        
        System.out.println("Cadastre o computador 1");
        System.out.print("Qual marca? ");
        comp1.marca = teclado.nextLine();
        
        System.out.print("Qual o modelo? ");
        comp1.modelo = teclado.nextLine();
        
        System.out.print("Qual o tipo (notebook, tablet, desktop)? ");
        comp1.tipo = teclado.nextLine();
        
        System.out.print("Qual o preço? R$ ");
        comp1.preco = teclado.nextDouble();
        
    
        Computador comp2 = new Computador(); 
        
        comp2.marca = "Positivo";
        comp2.modelo = "Motion 14 Q4128c";
        comp2.tipo = "Notebook";
