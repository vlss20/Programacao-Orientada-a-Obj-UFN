package pkg;

import java.util.InputMismatchException;
import java.util.Scanner;

public class ex6 {
    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);
        double premio = 5000.0;

        try {
            System.out.print("Quantos ganhadores dividirão o prêmio de R$ 5000.00? ");
            int ganhadores = teclado.nextInt();

            if (ganhadores == 0) {             
                throw new ArithmeticException("Divisão por zero");
            }

            double valorPorPessoa = premio / ganhadores;
            System.out.printf("Cada ganhador receberá: R$ %.2f\n", valorPorPessoa);

        } catch (ArithmeticException e) {
            System.out.println("Erro de cálculo: O número de ganhadores não pode ser zero (Divisão por zero)!");
        } catch (InputMismatchException e) {
            System.out.println("Erro de entrada: Por favor, digite um número inteiro válido de ganhadores.");
        } finally {
            teclado.close();
        }
    }
}

