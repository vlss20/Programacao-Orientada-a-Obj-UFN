package pkg;

import java.util.Scanner;
public class ex3 {
    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);

        System.out.print("Digite um valor: ");
        String valorTexto = teclado.nextLine();

        try {      
            double valorConvertido = Double.parseDouble(valorTexto);
            System.out.println("Conversão bem sucedida! O dobro desse valor é: " + (valorConvertido * 2));
            
        } catch (NumberFormatException e) {
            System.out.println("Erro: Não foi possível converter a string '" + valorTexto + "' para número.");
            System.out.println("Usar ponto em vez de vírgula e não digitar letras.");
        } finally {
            teclado.close();
        }
    }
}

