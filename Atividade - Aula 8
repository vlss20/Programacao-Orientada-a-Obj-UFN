package pkg;
import java.util.Scanner;

public class Usuario {

	String nomeUsuario;
	String senha;
	boolean logado = false; 
	
			public void login(String usuario, String senhaDigitada) {
        if (this.nomeUsuario.equals(usuario) && this.senha.equals(senhaDigitada)) {
            this.logado = true;
            System.out.println("Login realizado com sucesso!");
        } else {
            System.out.println("Usuário ou senha incorretos.");
        }
    }

    public void logout() {
        this.logado = false;
        System.out.println("Logout efetuado.");
    }

    public void exibirStatus() {
        String status = logado ? "Logado" : "Desconectado";
        System.out.println("Status atual: " + status);
    }

public static void main(String[] args) {
    Scanner leitor = new Scanner(System.in);
    Usuario user = new Usuario();
    user.nomeUsuario = "admin";
    user.senha = "1234";

    System.out.print("Digite o usuário: ");
    String u = leitor.nextLine();
    System.out.print("Digite a senha: ");
    String s = leitor.nextLine();

    user.login(u, s);
    user.exibirStatus();

    if (user.logado) {
        System.out.print("Deseja fazer logout? (s/n): ");
        if (leitor.next().equalsIgnoreCase("s")) {
            user.logout();
            user.exibirStatus();
        }
    }
}
}

