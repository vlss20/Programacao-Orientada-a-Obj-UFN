package pkg;
import java.util.Scanner;

public class Filme {
	String titulo;
    String diretor;
    int duracaoEmMinutos;
    String genero;

    public void exibirDetalhes() {
        System.out.println("\n--- Detalhes do Filme ---");
        System.out.println("Título: " + titulo);
        System.out.println("Diretor: " + diretor);
        System.out.println("Duração: " + duracaoEmMinutos + " min");
        System.out.println("Gênero: " + genero);
    }

    public boolean ehLongo() {
        return duracaoEmMinutos > 120;
    }
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);
        Filme f = new Filme();

        System.out.print("Título: ");
        f.titulo = leitor.nextLine();
        System.out.print("Diretor: ");
        f.diretor = leitor.nextLine();
        System.out.print("Gênero: ");
        f.genero = leitor.nextLine();
        System.out.print("Duração (min): ");
        f.duracaoEmMinutos = leitor.nextInt();

        f.exibirDetalhes();
        if (f.ehLongo()) {
            System.out.println("Este é um filme longo!");
        } else {
            System.out.println("Este é um filme de duração normal.");
        }
    }
}

