package pkg;
import java.util.Scanner;

public class Tarefa {
	String descricao;
    boolean concluida = false;

    public void concluirTarefa() {
        this.concluida = true;
    }

    public void exibirTarefa() {
        String status = concluida ? "[Concluída]" : "[Pendente]";
        System.out.println(status + " " + descricao);
    }
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);
        Tarefa[] lista = new Tarefa[3];
        for (int i = 0; i < 3; i++) {
            lista[i] = new Tarefa();
            System.out.print("Descrição da tarefa " + (i + 1) + ": ");
            lista[i].descricao = leitor.nextLine();
        }
        System.out.println("\nMarcando a tarefa 1 como concluída...");
        lista[0].concluirTarefa();
        System.out.println("\n--- Lista de Tarefas ---");
        for (Tarefa t : lista) {
            t.exibirTarefa();
        }
    }
}
