    public static void main(String[] args) {
        Retangulo meuRetangulo = new Retangulo();
        meuRetangulo.cor = "Azul";
        meuRetangulo.preenchido = true;
        meuRetangulo.largura = 5.0;
        meuRetangulo.altura = 10.0;
        
        System.out.println("Cor: " + meuRetangulo.cor);
        System.out.println("Preenchido: " + meuRetangulo.preenchido);
        System.out.println("Área do Retângulo: " + meuRetangulo.calcularArea());
    }
}

