package Projeto;

public class Computador {
    
    protected String Marca;

    private String Modelo;

    public Computador(String marca, String modelo) {
        this.Marca = marca;
        this.Modelo = modelo;
    }

    public String exibeModelo() {
        return Modelo;
    }
}

-------------------------------------------------------------------------------

package Projeto;

public class Notebook extends Computador {

    public Notebook(String marca, String modelo) {
        super(marca, modelo);
    }

    public String exibeMarca() {
        return Marca; 
    }

    public static void main(String[] args) {
        Notebook meuNote = new Notebook("Dell", "Inspiron 15");
        
        System.out.println("--- Dados do Notebook ---");
        System.out.println("Marca: " + meuNote.exibeMarca());
        System.out.println("Modelo: " + meuNote.exibeModelo());
    }
}

